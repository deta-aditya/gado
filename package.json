{
  "name": "gado",
  "version": "0.1.0",
  "description": "Functional programming primitives for TypeScript",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bunup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bunup": "^0.16.31",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
